# OpenF1 API (public, no token required)
OPENF1_BASE_URL=https://api.openf1.org/v1

# AI live-commentary accent (optional — the viz runs fine without it)
# AI_PROVIDER: huggingface-router | huggingface-legacy | none
AI_PROVIDER=huggingface-router
AI_MODEL=mistralai/Mistral-7B-Instruct-v0.3
AI_ROUTER_URL=https://router.huggingface.co/v1/chat/completions
HF_TOKEN=
