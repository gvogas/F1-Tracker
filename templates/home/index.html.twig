{% extends 'layout.html.twig' %}

{% block title %}F1 Tracker{% endblock %}

{% block content %}
<main>

  <!-- HERO -->
  <section class="hero card">
    <div class="checkers thin" style="margin-bottom:16px;"></div>

    <div class="hero-top">
      <div class="hero-badge"><i class="fa-solid fa-tower-broadcast"></i> Live F1 telemetry</div>
      <div class="hero-chip" id="favChip">Set your favourites in Profile</div>
    </div>

    <h1>F1 Tracker</h1>
    <p class="muted hero-sub">
      Lights out and away we go — follow live timing, the leaderboard, weather and
      AI race insights, all in one place.
    </p>

    <div class="cta">
      <a class="btn" href="/dashboard"><i class="fa-solid fa-flag-checkered"></i> Go to Live Dashboard</a>
      <a class="btn ghost" href="/races"><i class="fa-solid fa-calendar-days"></i> Races</a>
      <a class="btn ghost" href="/leaderboard"><i class="fa-solid fa-trophy"></i> Leaderboard</a>
      <a class="btn ghost" href="/profile"><i class="fa-solid fa-user-gear"></i> Profile</a>
    </div>

    <div class="hero-stats">
      <div class="stat">
        <div class="stat-num" id="statSeason">—</div>
        <div class="stat-label">Season</div>
      </div>
      <div class="stat">
        <div class="stat-num" id="statFavDriver">—</div>
        <div class="stat-label">Your driver</div>
      </div>
      <div class="stat">
        <div class="stat-num" id="statFavTeam">—</div>
        <div class="stat-label">Your team</div>
      </div>
    </div>
  </section>

  <!-- FEATURES -->
  <section class="grid">
    <a class="card card-link" href="/dashboard">
      <div class="card-icon"><i class="fa-solid fa-flag-checkered"></i></div>
      <h2>Live + Stats</h2>
      <p class="muted">Live timing tower, weather, and AI insights.</p>
    </a>

    <a class="card card-link" href="/leaderboard">
      <div class="card-icon"><i class="fa-solid fa-trophy"></i></div>
      <h2>Leaderboard</h2>
      <p class="muted">Browse races, sessions, and standings.</p>
    </a>

    <a class="card card-link" href="/profile">
      <div class="card-icon"><i class="fa-solid fa-user-gear"></i></div>
      <h2>Profile</h2>
      <p class="muted">Save your favourite driver and team.</p>
    </a>
  </section>

  <!-- ABOUT -->
  <section class="card about">
    <h2>About</h2>
    <ul class="bullets muted">
      <li>PHP backend with Slim 4 + Twig (server-side rendering)</li>
      <li>All data proxied and cached server-side via OpenF1</li>
      <li>AI commentary, strategy analysis, and race prediction via HuggingFace</li>
      <li>User preferences stored in cookies</li>
    </ul>
  </section>

</main>
{% endblock %}

{% block scripts %}
<script src="/features/home/home.page.js"></script>
{% endblock %}
